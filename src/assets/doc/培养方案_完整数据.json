      "text": "三、学制与学位授予"
    },
    {
      "idx": 15,
      "level": "Heading 2",
      "text": "四、基本学分要求"
    },
    {
      "idx": 17,
      "level": "Heading 2",
      "text": "五、课程设置与学分分布"
    },
    {
      "idx": 18,
      "level": "Heading 3",
      "text": "1．通识课  48 学分"
    },
    {
      "idx": 21,
      "level": "Heading 4",
      "text": "（1）思想政治理论课  18学分"
    },
    {
      "idx": 22,
      "level": "Heading 5",
      "text": "1）必修 17学分"
    },
    {
      "idx": 23,
      "level": "Heading 5",
      "text": "2）限选课 1学分"
    },
    {
      "idx": 28,
      "level": "Heading 4",
      "text": "(2) 体育  4学分"
    },
    {
      "idx": 31,
      "level": "Heading 4",
      "text": "(3) 外语（一外英语学生必修8学分，一外其他语种学生必修6学分）"
    },
    {
      "idx": 34,
      "level": "Heading 4",
      "text": "（4）写作与沟通课 必修 2学分"
    },
    {
      "idx": 36,
      "level": "Heading 4",
      "text": "(5) 军事课程  4学分 3周"
    },
    {
      "idx": 39,
      "level": "Heading 4",
      "text": "(6) 通识课程特殊要求如下："
